{
	admin 0.0.0.0:2019
	metrics {
		per_host
	}

	local_certs
}

app.localhost {
	reverse_proxy backend1:80 backend2:80 backend3:80 {
		lb_policy round_robin
		health_uri /
		health_interval 10s
		health_timeout 2s
	}
}

api.localhost {
	handle /health {
		respond "OK" 200
	}

	handle /error {
		respond "Internal Error" 500
	}

	handle /notfound {
		respond "Not Found" 404
	}

	# Dynamic-segment endpoints to exercise Ember's "By Route" normalization
	# (UUIDs collapse to :uuid, all-digit segments to :id, 16+ hex chars to
	# :hash). Wildcards make Caddy match every value while load.sh varies the
	# concrete segment on every request.
	handle /users/* {
		respond "User" 200
	}
	handle /orders/* {
		respond "Order" 200
	}
	handle /sessions/* {
		respond "Session" 200
	}
	handle /artifacts/* {
		respond "Artifact" 200
	}

	handle {
		respond "Hello API" 200
	}
}

static.localhost {
	respond "Hello from static site" 200
}
